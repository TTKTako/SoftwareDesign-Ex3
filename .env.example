# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Django secret key (required)
SECRET_KEY="django-insecure-replace-me-with-a-long-random-string"

# -----------------------------------------------------------------------
# Song generation strategy
# -----------------------------------------------------------------------
# mock  → offline, deterministic, no API key required (default)
# suno  → live Suno API (requires SUNO_API_KEY below)
GENERATOR_STRATEGY=mock

# Suno API key — only needed when GENERATOR_STRATEGY=suno
# Obtain yours from https://sunoapi.org/api-key
SUNO_API_KEY=

# -----------------------------------------------------------------------
# Google OAuth 2.0 (FR-1.1, FR-1.2)
# -----------------------------------------------------------------------
# Create credentials at https://console.cloud.google.com/
#   1. Create a project → APIs & Services → Credentials
#   2. Create OAuth 2.0 Client ID (Web application)
#   3. Add ALL of the following as Authorised redirect URIs:
#
#      Local development:
#        http://127.0.0.1:8000/accounts/google/login/callback/
#        http://localhost:8000/accounts/google/login/callback/
#
#      Production (replace with your real domain):
#        https://yourdomain.com/accounts/google/login/callback/
#
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
